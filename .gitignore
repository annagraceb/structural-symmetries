results/aligned_*/

# Rotation matrices (regenerable in same alignment step)
results/R_*.npy
results/deep/R_*.npy
results/deep/aligned_*/
results/deep8/R_*.npy
results/deep8/aligned_*/
results/modp/R_*.npy
results/modp/aligned_*/

# Build artifact (regenerable via build_pdf.py)
/paper_build.html

# Run1 and auxiliary training artifacts (large, not part of the P1 story)
run1_reversed/
models_auxiliary/
models_step8_rerun/
