# Python bytecode
__pycache__/
*.pyc
*.pyo
*.pyd

# Local scratch / build
/tmp/
*.egg-info/
.venv/
.env
.pytest_cache/

# Claude Code local data
.claude/

# Activations: regenerable from saved model weights via collect_activations*.py
